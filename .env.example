# ============================================================
# Banco Ágil — Multi-Agent Banking System
# ============================================================

# LLM Provider: "ollama" para dev local, "google" ou "groq" para produção
LLM_PROVIDER=groq

# Ollama settings (quando LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Google Generative AI settings (quando LLM_PROVIDER=google)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-2.0-flash

# Groq settings (quando LLM_PROVIDER=groq)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
